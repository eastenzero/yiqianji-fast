# ============================================================
# 医前记 - 环境变量示例
# 复制本文件为 .env.local 并填入你的真实 Key
# ============================================================

# 通义千问 API Key
# 申请地址：https://bailian.console.aliyun.com/?apiKey=1#/api-key
VITE_QWEN_API_KEY=sk-your-api-key-here

# 通义千问 OpenAI 兼容接口 Base URL（一般无需修改）
VITE_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 文本模型（摘要生成）：qwen-turbo / qwen-plus / qwen-max
VITE_QWEN_TEXT_MODEL=qwen-plus

# 多模态模型（OCR 识别报告）：qwen-vl-plus / qwen-vl-max
VITE_QWEN_VL_MODEL=qwen-vl-plus

# ============================================================
# 火山引擎 TTS 语音合成（仅用于视频配音生成 · video/ 脚本）
# 控制台地址：https://www.volcengine.com · 语音合成大模型
# 新用户 100 万字免费额度
# ============================================================
VOLCENGINE_APPID=your_app_id_here
VOLCENGINE_ACCESS_TOKEN=your_access_token_here
VOLCENGINE_SECRET=your_secret_if_needed
VOLCENGINE_CLUSTER=volcano_tts
